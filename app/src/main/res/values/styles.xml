<resources>
    <!-- Application theme -->
    <style name="AppTheme.V21" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/jellyfin_primary</item>
        <item name="colorPrimaryDark">@color/jellyfin_primary_dark</item>
        <item name="colorAccent">@color/jellyfin_accent</item>
        <item name="android:windowBackground">@color/theme_background</item>
        <item name="android:navigationBarColor">@color/theme_background</item>
    </style>

    <style name="AppTheme" parent="AppTheme.V21" />

    <!-- Classic launch splash: the windowBackground (dark + centered wordmark) is
         shown by the system for the ENTIRE cold start, then onCreate switches to
         the real AppTheme. No Android-12 SplashScreen icon slot (circle mask), no
         separate in-app fade. -->
    <style name="AppTheme.Starting" parent="AppTheme.V21">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>

    <!-- Settings theme -->
    <style name="AppTheme.Settings" />

    <!-- Theme Overlays -->
    <style name="ThemeOverlay.App.BackButton" parent="">
        <item name="colorControlNormal">?android:textColorPrimary</item>
    </style>
</resources>
