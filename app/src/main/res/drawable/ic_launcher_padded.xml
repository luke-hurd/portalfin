<?xml version="1.0" encoding="utf-8"?>
<!-- Launcher icon with built-in padding so Portal's launcher doesn't clip
     the triangle outline. Background is the Portal-dark gradient color from
     ic_launcher_background; foreground is the transparent logo PNG inset. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/ic_launcher_background" />
            <corners android:radius="0dp" />
        </shape>
    </item>
    <item
        android:left="14dp"
        android:right="14dp"
        android:top="14dp"
        android:bottom="14dp">
        <bitmap
            android:src="@drawable/ic_launcher_logo"
            android:gravity="center"
            android:antialias="true"
            android:filter="true" />
    </item>
</layer-list>
