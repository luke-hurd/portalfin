<?xml version="1.0" encoding="utf-8"?>
<!-- The portalfin header is a STATIC overlay above the fragment container, so it
     stays put while fragments animate beneath it (it used to live inside each
     fragment and rode along with the transition). Only shown on the native
     home/library screens; MainActivity toggles its visibility. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout="@layout/fragment_connect"
        tools:viewBindingIgnore="true" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/portal_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:visibility="gone" />

    <!-- Ambient screensaver overlay. Activity-level so it covers ALL screens
         (native home/library/detail + the WebView player) edge-to-edge above the
         Portal top inset. Shown by MainActivity after idle; GONE otherwise. -->
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/ambient_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />
</FrameLayout>
